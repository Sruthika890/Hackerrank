using namespace std;
void mergeArrays(int arr1[],int n,int arr2[],int m){
        int i=0,j=0;
        while(i<n&&j<m){
        if(arr1[i]<=arr2[j])
        cout<<arr1[i++]<<" ";
        else
        cout<<arr2[j++]<<" ";
        }
        while(i<n)
        cout<<arr1[i++]<<" ";
        while(j<m)
        cout<<arr2[j++]<<" ";
}
int main() {
    int n,m;
    cin>>n;
    int arr1[n];
    for(int i=0;i<n;i++)
    cin>>arr1[i];
    cin>>m;
    int arr2[m];
    for(int i=0;i<m;i++)
    cin>>arr2[i];
    mergeArrays(arr1,n,arr2,m);
        
    /* Enter your code here. Read input from STDIN. Print output to STDOUT */   
